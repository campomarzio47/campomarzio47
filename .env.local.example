# Copia questo file in .env.local (in locale) e imposta le stesse variabili
# nelle Environment Variables del progetto su Vercel per il deploy.

# Account Gmail usato per inviare le email dal sito (check-in e contatti).
# GMAIL_APP_PASSWORD non è la password normale di Gmail: va generata da
# https://myaccount.google.com/apppasswords (richiede la verifica in due passaggi attiva).
GMAIL_USER=tuoaccount@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Indirizzo a cui arrivano le email di check-in e contatto.
HOST_EMAIL=campomarzio47.marostica@gmail.com

# Facoltativi: link "Esporta calendario" (iCal) dal pannello host di Airbnb e
# Booking.com. Se assenti, la pagina Disponibilità mostra solo i bottoni
# verso le piattaforme, senza calendario live.
AIRBNB_ICAL_URL=
BOOKING_ICAL_URL=

# Codice struttura assegnato dall'ente regionale per la movimentazione
# turistica (Ross1000/GIES). Senza questo valore il campo <codice> dell'XML
# resta "DA_COMPILARE" e va corretto a mano prima del caricamento.
ROSS1000_CODICE_STRUTTURA=

# Facoltativi: nome del "prodotto" (software/sito) e numero di letti
# disponibili della struttura, usati nell'XML. Se assenti, il sito usa
# rispettivamente "CampoMarzio47Website" e 4.
ROSS1000_PRODOTTO=
ROSS1000_LETTI_DISPONIBILI=
